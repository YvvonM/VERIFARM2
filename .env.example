# VeriFarms — environment template.
# Copy to `.env` and fill in real values locally (`.env` is git-ignored).
# Every variable is optional unless noted; shown values are the code defaults.

# ─── Core API ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
RELOAD=true
LOG_LEVEL=INFO
# Comma-separated allowed origins for the browser frontend.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Neo4j (graph store) ─────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# ─── Agent LLM (Featherless, OpenAI-compatible — serves Qwen3) ────────────────
# When FEATHERLESS_API_KEY is empty the agent falls back to a deterministic
# mock stream, so the app still runs without a key.
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL=Qwen/Qwen3-235B-A22B-Thinking-2507
FEATHERLESS_ROUTER_MODEL=
FEATHERLESS_VISION_MODEL=

# ─── API auth + rate limit (all routers; opt-in) ─────────────────────────────
# Set a key to require X-API-Key (or ?api_key= for the SSE/EventSource chat).
# Open when unset. EXPORT_API_KEY is a legacy alias for VERIFARMS_API_KEY.
VERIFARMS_API_KEY=
EXPORT_API_KEY=
EXPORT_RATE_LIMIT_PER_MIN=120

# ─── Remote MCP gateway (multi-tenant, read-only; mounted at /mcp) ────────────
MCP_REMOTE_ENABLED=false
# Production: HS256 JWT secret used to verify org-scoped Bearer tokens.
MCP_JWT_SECRET=
# Dev only: accept unsigned base64url JSON tokens. Never enable in production.
MCP_AUTH_DEV=false
MCP_RATE_LIMIT_PER_MIN=60          # per-tenant; 0 disables
MCP_PORT=9000                      # only for the standalone `app.mcp.remote` host

# ─── Event publishing (outbound claim events) ────────────────────────────────
EVENT_BACKEND=none                 # none | webhook | redis
EVENT_WEBHOOK_URLS=                # comma-separated, when EVENT_BACKEND=webhook
EVENT_REDIS_CHANNEL=verifarms.claims
ALERT_WEBHOOK_URL=                 # investigator/data-quality alerts

# ─── Streaming ingestion (RabbitMQ telemetry) ────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
REDIS_URL=                         # optional: dedup / cache / pub-sub
STREAM_DEDUP_BACKEND=memory        # memory | redis
REGISTRY_CACHE_BACKEND=memory      # memory | redis

# ─── Inbound connector (cooperative Postgres registry) ───────────────────────
# Leave COOP_PG_DSN blank to use the demo coop-postgres (see docker-compose.yml /
# scripts/demo_phase1.sh); set it to point the connector at a real registry.
#   demo (compose network):  postgresql+asyncpg://verifarms:verifarms@coop-postgres:5432/coop
#   demo (host / local run):  postgresql+asyncpg://verifarms:verifarms@localhost:5433/coop
COOP_PG_DSN=                       # e.g. postgresql+asyncpg://user:pass@host:5432/db
COOP_PG_TABLE=cooperative_members
COOP_PG_POOL_SIZE=5
COOP_PG_MAX_OVERFLOW=10
COOP_PG_POOL_RECYCLE=1800

# ─── Bulk-spatial object store (S3 / MinIO) ──────────────────────────────────
# The bulk connector (app.bulk.s3_connector) fetches GeoJSON parcels from here.
# Leave BULK_S3_ENDPOINT_URL blank for real AWS S3; set it for a local MinIO
# (see docker-compose.yml / scripts/demo_phase3.sh). Credentials use the standard
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY below.
BULK_S3_BUCKET=verifarms-bulk
BULK_S3_PREFIX=spatial/
BULK_S3_ENDPOINT_URL=              # demo MinIO: http://localhost:9000
AWS_ACCESS_KEY_ID=                # demo MinIO: minioadmin
AWS_SECRET_ACCESS_KEY=            # demo MinIO: minioadmin

# ─── Secrets backend (resolves the secrets above) ────────────────────────────
SECRETS_BACKEND=env                # env | aws | vault
AWS_REGION=
AWS_SECRETS_PREFIX=
VAULT_ADDR=
VAULT_TOKEN=
VAULT_KV_MOUNT=secret
VAULT_SECRETS_PATH=verifarms

# ─── Verification sources ────────────────────────────────────────────────────
# Google Earth Engine (NDVI cross-check). Provide a key path OR inline JSON.
EE_PROJECT_ID=
EE_SERVICE_ACCOUNT_KEY_PATH=
EE_SERVICE_ACCOUNT_KEY_JSON=
LAND_REGISTRY_BASE_URL=

# Credit-bureau / identity provider seam (app.verification.providers.factory).
# All three of each trio must be set, else the factory raises NotConfigured and
# NO credit_history / identity_verified claims are produced (the system never
# fabricates). The demo registers a "demo" provider against the stub bureau:
#   CREDIT_PROVIDER=demo  CREDIT_API_KEY=demo-key  CREDIT_BASE_URL=http://localhost:8001
#   IDENTITY_PROVIDER=demo IDENTITY_API_KEY=demo-key IDENTITY_BASE_URL=http://localhost:8001
CREDIT_PROVIDER=
CREDIT_API_KEY=
CREDIT_BASE_URL=
IDENTITY_PROVIDER=
IDENTITY_API_KEY=
IDENTITY_BASE_URL=

# ─── DLQ Investigator (background data-quality worker) ───────────────────────
INVESTIGATOR_ENABLED=false
INVESTIGATOR_INTERVAL_SECONDS=300
INVESTIGATOR_VARIANCE_THRESHOLD=0.20
DLQ_PATH=                          # path for dead-lettered ingest records

# ─── Frontend (Next.js, build-time public vars) ──────────────────────────────
NEXT_PUBLIC_API_BASE=http://localhost:8000
# Only set if VERIFARMS_API_KEY is configured (travels in the SSE URL).
NEXT_PUBLIC_API_KEY=
